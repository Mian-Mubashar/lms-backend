# Copy to .env (never commit .env). On Vercel, set the same keys in Project → Settings → Environment Variables.

# If the browser shows "CORS" but Network shows 401 + HTML (no JSON): Vercel is blocking BEFORE Express.
# Fix: Vercel → this BACKEND project → Settings → Deployment Protection → turn OFF Vercel Authentication
# (or "Only Preview" / Standard Protection) so public API URLs are reachable. Preview URLs often need this.

# Required on Vercel / production (MongoDB Atlas — include DB path, not only ?appName=...)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/lms_database?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=use_a_long_random_string_at_least_32_chars

# CORS: exact frontend origin(s), no trailing slash
FRONTEND_URL=https://lms-frontend-six-silk.vercel.app/
# Optional extra origins (comma-separated): staging, custom domain
# CORS_ORIGINS=https://www.example.com,https://staging.example.com

# Optional: CORS_STRICT=1 to only allow FRONTEND_URL + CORS_ORIGINS + *.vercel.app + localhost
# CORS_STRICT=1

PORT=5000
NODE_ENV=development

# First-time local login: create demo admin (admin@lms.com / Password123!) — run from backend folder:
# npm run db:seed:demo-admin
# If user exists but password unknown: npm run db:seed:demo-admin -- --reset
#
# Atlas: same MONGODB_URI as above; open terminal in `backend`, then run the same commands (your IP must be allowed in Atlas → Network Access).
#
